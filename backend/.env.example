# Server Configuration
NODE_ENV=development
PORT=3002

# MongoDB
MONGODB_URI=mongodb://localhost:27017/cattle_health

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# Session
SESSION_SECRET=your_session_secret_here

# CORS
CLIENT_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=15 * 60 * 1000  # 15 minutes
RATE_LIMIT_MAX=100  # Limit each IP to 100 requests per window

# Email (for future use)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_EMAIL=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM='Cattle Health <noreply@cattlehealth.com>'

# Flask ML API (for future integration)
FLASK_ML_API_URL=http://localhost:5000

# Logging
LOG_LEVEL=info

# Security
PASSWORD_RESET_EXPIRE=3600000  # 1 hour in milliseconds

# Frontend URLs
FRONTEND_URL=http://localhost:3000
PASSWORD_RESET_URL=/reset-password

# Environment-specific overrides
# Create .env.development, .env.production, etc. for environment-specific settings
