# Server Configuration
NODE_ENV=development
PORT=3002

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/cattleMonitor

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# Email Configuration (for production)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USERNAME=apikey
EMAIL_PASSWORD=your_sendgrid_api_key
EMAIL_FROM=no-reply@cattlehealth.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000 # 1 hour in milliseconds
RATE_LIMIT_MAX=100 # Max requests per window

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Security
MAX_REQUEST_BODY_SIZE=10kb
MAX_REQUEST_URLENCODED=10kb

# Session
SESSION_SECRET=your_session_secret_here
SESSION_EXPIRES_IN=30d
